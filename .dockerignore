# ── Version control ──────────────────────────────────
.git
.gitignore
.github

# ── Python cache / build artifacts ───────────────────
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/*.egg-info
**/*.egg
**/.eggs
**/dist
**/build
**/.venv
**/venv
**/.env
**/.env.*
!**/.env.example

# ── Rust build artifacts ──────────────────────────────
engines/rust/target
**/target/debug
**/target/release
**/target/.rustc_info.json

# ── Node / Frontend ───────────────────────────────────
frontend/node_modules
frontend/.next
frontend/out
frontend/.turbo
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# ── ML / Data ─────────────────────────────────────────
**/*.csv
**/*.parquet
**/*.pkl
**/*.h5
**/*.pt
**/*.pth
**/*.onnx
**/mlruns
**/mlflow.db
ml/models
ml/notebooks/.ipynb_checkpoints

# ── IDE / OS ──────────────────────────────────────────
.DS_Store
.idea
.vscode
**/*.swp
**/*.swo
**/Thumbs.db

# ── Local Environment / Hidden Files ──────────────────
.local_docker/
.local_tmp/
.tsbuildinfo
*.tsbuildinfo
frontend/.next-*/

