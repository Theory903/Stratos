BSE_RSS_URL=https://www.bseindia.com/rss-feed.xml
NEWS_API_KEY=

# ── Auth ──
AUTH_COOKIE_SECRET=replace-with-32-byte-random-secret
JWT_SECRET=changeme
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# ── Service Ports ──
DATA_FABRIC_PORT=8001
ENGINES_JAVA_PORT=8002
ML_SERVICE_PORT=8003
NLP_SERVICE_PORT=8004
ORCHESTRATOR_PORT=8005
FRONTEND_PORT=3000
NEXT_PUBLIC_ENABLE_DEMO=false
