# ── Data Fabric Infra ──
DF_POSTGRES_URL=postgresql+asyncpg://stratos:password@localhost:5432/stratos
DF_MONGO_URL=mongodb://localhost:27017
DF_MONGO_DATABASE=stratos
DF_REDIS_URL=redis://localhost:6379
DF_KAFKA_BROKERS=localhost:9092
DF_S3_ENDPOINT=http://localhost:9000
DF_S3_ACCESS_KEY=minioadmin
DF_S3_SECRET_KEY=minioadmin
DF_S3_BUCKET=stratos-data
DF_QDRANT_URL=http://localhost:6333

# ── LLM Providers ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Select one: ollama | openai | groq | nvidia
ORCHESTRATOR_LLM_PROVIDER=ollama

# Optional override for the LangChain v3 runtime model regardless of provider default.
ORCHESTRATOR_LANGCHAIN_AGENT_MODEL=

# Ollama
ORCHESTRATOR_OLLAMA_MODEL=kimi-k2.5:cloud
ORCHESTRATOR_OLLAMA_BASE_URL=http://host.docker.internal:11434

# OpenAI
ORCHESTRATOR_OPENAI_MODEL=gpt-4-turbo-preview
ORCHESTRATOR_OPENAI_API_KEY=

# Groq
ORCHESTRATOR_GROQ_MODEL=moonshotai/kimi-k2-instruct-0905
ORCHESTRATOR_GROQ_API_KEY=
ORCHESTRATOR_GROQ_API_BASE=https://api.groq.com/openai/v1

# NVIDIA
ORCHESTRATOR_NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b
ORCHESTRATOR_NVIDIA_API_KEY=
ORCHESTRATOR_NVIDIA_TEMPERATURE=1.0
ORCHESTRATOR_NVIDIA_TOP_P=0.95
ORCHESTRATOR_NVIDIA_MAX_TOKENS=16384
ORCHESTRATOR_NVIDIA_REASONING_BUDGET=16384
ORCHESTRATOR_NVIDIA_ENABLE_THINKING=true
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=stratos-orchestrator

# ── Data Sources ──
FRED_API_KEY=
POLYGON_API_KEY=
MASSIVE_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io
MASSIVE_BASE_URL=https://api.massive.com
UPSTOX_API_KEY=
UPSTOX_BASE_URL=https://api.upstox.com
COINAPI_API_KEY=
COINAPI_BASE_URL=https://rest.coinapi.io
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stratos-data-fabric/0.1
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_BASE_URL=https://api.x.com/2
OANDA_API_KEY=
WORLD_BANK_BASE_URL=https://api.worldbank.org/v2
SEC_BASE_URL=https://data.sec.gov
SEC_TICKER_MAP_URL=https://www.sec.gov/files/company_tickers.json
SEC_USER_AGENT=STRATOS Research support@makeuslive.com
RBI_RSS_URL=https://www.rbi.org.in/Scripts/RSS.aspx?Id=4
